# OpenAI API Configuration
# Copy this file to .env and fill in your details.

# Your OpenAI API key (required)
OPENAI_API_KEY=your-api-key-here

# The LLM model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: Custom API Base URL (useful if using Ollama, LM Studio, Anyscale, OpenRouter, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Tavily Search API Configuration
# Your Tavily API key (required)
TAVILY_API_KEY=your-tavily-key-here

# Production settings (optional)
# SECRET_KEY=generate-a-random-secret
# DATABASE_PATH=/tmp/researchai.db
# HOST=0.0.0.0
# PORT=5000
